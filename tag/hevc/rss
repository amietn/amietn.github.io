<rss version="2.0"><channel><title>tome.one - hevc</title><link>https://tome.one/</link><description></description><lastBuildDate>Fri, 26 May 2017 13:40:00 +0200</lastBuildDate><item><title>Playing 10bit HEVC videos on Linux with NVIDIA and mpv</title><link>https://tome.one/playing-10bit-hevc-videos-on-linux-with-nvidia-and-mpv.html</link><description>&lt;p&gt;For this to work you will need an NVIDIA GPU.&lt;/p&gt;
&lt;p&gt;Get the &lt;code&gt;mpv-build&lt;/code&gt; scripts, tune the mpv and ffmpeg options and build:&lt;/p&gt;
&lt;div class="highlight"&gt;&lt;pre&gt;&lt;span&gt;&lt;/span&gt;&lt;code&gt;&lt;span class="ch"&gt;#!/bin/sh&lt;/span&gt;

mkdir -p ~/git
&lt;span class="nb"&gt;cd&lt;/span&gt; ~/git
git clone https://github.com/mpv-player/mpv-build.git
&lt;span class="nb"&gt;cd&lt;/span&gt; mpv-build

&lt;span class="c1"&gt;# write mpv_options file&lt;/span&gt;
cat &lt;span class="s"&gt;&amp;lt;&amp;lt; EOF &amp;gt; mpv_options&lt;/span&gt;
&lt;span class="s"&gt;--enable-cuda-hwaccel&lt;/span&gt;
&lt;span class="s"&gt;EOF&lt;/span&gt;

&lt;span class="c1"&gt;# write ffmpeg_options file …&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;</description><dc:creator xmlns:dc="http://purl.org/dc/elements/1.1/">tome.one</dc:creator><pubDate>Fri, 26 May 2017 13:40:00 +0200</pubDate><guid isPermaLink="false">tag:tome.one,2017-05-26:/playing-10bit-hevc-videos-on-linux-with-nvidia-and-mpv.html</guid><category>dev</category><category>linux</category><category>hevc</category><category>video</category></item></channel></rss>